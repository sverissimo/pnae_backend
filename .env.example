# .env.example — canonical template for all environments
#
# This backend uses one env file per environment at the project root,
# all ignored by `*.env` in .gitignore (real values stay out of the repo):
#
#   development.env  — dev container         (docker-compose.dev.yaml)
#   homolog.env      — staging container     (docker-compose.hmg.yaml,
#                                             docker-compose.hmg-infra.yaml)
#   production.env   — production container  (docker-compose.prod.yaml)
#
# This is the single canonical template for all three. To set up an
# environment, copy this file to the matching <env>.env name and fill
# in real values. The per-env differences are flagged inline below
# (search for "[dev only]", "[hmg+prod]", "[dev+hmg]").
#
# LDAP credentials, JWT secrets, DB connection strings, CLIENT_TOKEN
# and any other secret must never end up in a tracked file.

# ── Runtime ───────────────────────────────────────────────────────────
# NODE_ENV=                              # development | homolog | production
# PORT=

# ── LDAP (AD login) ───────────────────────────────────────────────────
# LDAP_SERVER=ldap://<ldap-host>
# LDAP_PORT=389
# LDAP_PASSWORD=<ldap-bind-password>
# LDAP_BASE=dc=...,dc=...,dc=...
# LDAP_BIND_DN=CN=...,OU=...,DC=...
# LDAP_UID=sAMAccountName

# ── Tokens / secrets ──────────────────────────────────────────────────
# PNAE_WEB_TOKEN=<base64-shared-token>
# CLIENT_TOKEN=<base64-shared-token>
# JWT_SECRET=<jwt-signing-secret>

# ── Container UID/GID for the host user ───────────────────────────────
# HOST_UID=1001
# HOST_GID=1001

# ── Folders (host vs container paths) ─────────────────────────────────
# HOST_FOLDER=<absolute path to pnae_app on the host>
# HOME_FOLDER=/home/node/app
# FILES_FOLDER=/home/node/data_dev      # container path; differs per env mount
# LOGS_FOLDER=/home/node/logs
# ZIP_FILES_PATH=/home/node/zipFiles
# ALLOWED_USER_IDS=<comma-separated admin user ids>

# DB_FOLDER=<absolute host path>        # [dev only]  host bind for postgres data

# ── Database ──────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
# POSTGRES_USER=<db-user>
# POSTGRES_PASSWORD=<db-password>
# POSTGRES_DB=<db-name>

# ── Redis (BullMQ broker) ─────────────────────────────────────────────
# REDIS_URL=redis://<redis-host>:6379

# ── External GraphQL server (emater_graphql_server) ───────────────────
# GRAPHQL_SERVER_URL=http://<graphql-host>:<port>
# GRAPHQL_SERVER_AUTH=<base64-auth>

# ── HTTP / CORS ───────────────────────────────────────────────────────
# BASE_URL=<public base url>            # [hmg+prod] public origin of the API
# CORS_ALLOWED_ORIGINS=<o1>,<o2>        # [dev+hmg]  comma-separated origins; unset in prod
#                                       #            (prod traffic terminates at nginx same-origin)
